# ==============================
# Servidor
# ==============================
NODE_ENV=development
PORT=10000
ADMIN_KEY=cambia_esta_clave_admin
PUBLIC_BASE_URL=https://tu-app.onrender.com

# Lista de orígenes permitidos separada por comas.
# Déjalo vacío si la web y la API van en el mismo dominio.
ALLOWED_ORIGINS=

# ==============================
# Supabase (solo servidor)
# ==============================
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE=tu_service_role_de_supabase

# ==============================
# Velocidrone API
# ==============================
VELO_API_URL=https://velocidrone.co.uk/api/leaderboard
VELO_API_TOKEN=tu_token_velocidrone
SIM_VERSION=1.16
CACHE_TTL_MS=600000

# ==============================
# Telegram bot (opcional pero ya preparado)
# ==============================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=pon_un_secreto_largo_y_unico
# IDs permitidos separados por comas. Ejemplo: -1001234567890,-1009876543210
TELEGRAM_ALLOWED_CHAT_IDS=
